{
  "pattern_id": "heartbeat_base",
  "name": "Heartbeat Base (Statistical)",
  "category": "price_action",
  "description": "Statistical baseline-plus-pulse base detector. Finds compression bases with repeated top/floor touches, requires prior decline, confirms breakout by significance (z-score vs base volatility), and keeps setup valid while price holds above base floor.",
  "author": "system",
  "version": "1.0.0",
  "plugin_file": "plugins/heartbeat_base_primitive.py",
  "plugin_function": "run_heartbeat_base_primitive_plugin",
