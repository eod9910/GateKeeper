      "type": "float",
      "min": 0.01,
      "max": 0.2,
      "step": 0.01,
      "default": 0.08
    },
    {
      "key": "head_dominance_pct",
      "label": "Head Dominance",
      "type": "float",
      "min": 0.005,
      "max": 0.1,
      "step": 0.005,
      "default": 0.015
    },
    {
      "key": "neckline_tolerance_pct",
      "label": "Neckline Tolerance",
