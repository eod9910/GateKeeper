{
  "pattern_id": "compression_box_recurrence_v1_pattern",
  "name": "Compression Box Recurrence V1 (Pattern)",
  "category": "price_action",
  "description": "Detects volatility-compression bases using ATR-normalized box width, efficiency ratio, slope, and recurrence, then annotates base top/bottom for visual review.",
  "author": "system",
  "version": "1.0.0",
  "plugin_file": "plugins/compression_box_recurrence_v1_pattern.py",
  "plugin_function": "run_compression_box_recurrence_v1_pattern_plugin",
  "pattern_type": "compression_box_recurrence_v1_pattern",
  "artifact_type": "pattern",
  "composition": "preset",
  "pattern_role": "phase_structure_pattern",
  "default_structure_config": {
    "swing_method": "rdp",
    "swing_epsilon_pct": 0.05
  },
  "default_setup_params": {
